{
    "manifest_version": 3,
    "name": "Lock In Timer",
    "version": "1.0",
    "homepage_url": "https://github.com/mae77tro/Lockin-extension", 
    
    "description": "Helps you lock in while studying", 

    "icons":{
        "96": "icons/lockin-96.png",
        "48": "icons/lockin-48.png"
    },

    "browser_specific_settings": {
        "gecko": {
            "id": "daniel.azagra0@gmail.com",
            "data_collection_permissions": {
                "required": ["none"]
            }
        }
    },
    "action": {
        "default_icon": "icons/lockin-48.png",
        "default_title": "Lock in",
        "default_popup": "popup/popup.html"    
    },

    "content_scripts": [
        {
            "matches": ["*://*.nrk.no/*"],
            "js": ["timer.js"]
        }
    ],
    "background": {
        "scripts": ["background.js"]
    }
}