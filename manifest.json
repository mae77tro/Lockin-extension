{
    "manifest_version": 3,
    "name": "Lock In Timer",
    "version": "1.0",
    "homepage_url": 
    
    "description": "Helps you lock in while studying", 

    "icons":{
        "96": "icons/lockin-96.png",
        "48": "icons/lockin-48.png"
    },

    "browser_specific_settings": {
        "gecko": {
            "id": "daniel.azagra0@gmail.com",
            "data_collection_permissions": {
                "required": ["none"]
            }
        }
    },
    "action": {
        "default_icon": "icons/lockin-48.png",
        "theme_icons": [
            {
                "light": "icons/lockin-48.png"
            }
        ],
        "default_title": "Lock in",
        "default_popup": "popup/choose_beast.html"    
    },

    "content_scripts": [
        {
            "matches": ["*://*.nrk.no/*"],
            "js": ["borderify.js"]
        }
    ]
}